# HTTP / logging
PORT=4100
LOG_LEVEL=info
LOG_STATE_EVENTS=0
ENABLE_RUNTIME_PERSISTENCE=0

# Database
DATABASE_URL=postgres://postgres:postgres@localhost:5432/runner

# Solana RPC
SOLANA_RPC_HTTP=https://api.devnet.solana.com
SOLANA_RPC_WS=wss://api.devnet.solana.com

# Comma-separated allowlist for Socket.IO origins. Add your LAN URL when testing from device (e.g. http://192.168.1.100:8081).
SOCKET_IO_CORS_ORIGINS=http://localhost:8081,http://localhost:19006

# Custodial vault
# Public key used for inbound deposits and outbound payouts/withdrawals.
VAULT_PUBLIC_KEY=REPLACE_WITH_VAULT_PUBLIC_KEY

# JSON array of the 64-byte Ed25519 secret key used by the custodial signer worker.
# Example: [12,34,...]
VAULT_SECRET_KEY_JSON=REPLACE_WITH_SECRET_KEY_JSON

# Public base URL the mobile app can reach for generated character assets when using local file storage.
SERVER_PUBLIC_BASE_URL=http://192.168.1.100:4100

# AI character generation
CHARACTER_GENERATION_ENABLED=1
CHARACTER_GENERATION_TOKEN_ID=sol
CHARACTER_GENERATION_ENTRY_FEE_TIER_ID=sol-001
CHARACTER_GENERATION_MAX_CONCURRENT_JOBS=5
GEMINI_API_KEY=REPLACE_WITH_GEMINI_API_KEY
CHARACTER_LOCAL_ASSET_DIR=.data/character-assets

# Optional Railway bucket / S3-compatible storage. Leave these unset to use local file storage instead.
# Railway bucket credentials map like this:
# - CHARACTER_BUCKET_NAME <- BUCKET
# - CHARACTER_BUCKET_ENDPOINT <- ENDPOINT
# - CHARACTER_BUCKET_REGION <- REGION
# - CHARACTER_BUCKET_ACCESS_KEY <- ACCESS_KEY_ID
# - CHARACTER_BUCKET_SECRET_KEY <- SECRET_ACCESS_KEY
# For Railway buckets, keep CHARACTER_BUCKET_SIGNED_URLS=1 unless you have configured a separate public asset base URL.
CHARACTER_BUCKET_NAME=runner-character-assets
CHARACTER_BUCKET_ENDPOINT=https://REPLACE_ME
CHARACTER_BUCKET_REGION=auto
CHARACTER_BUCKET_ACCESS_KEY=REPLACE_WITH_ACCESS_KEY
CHARACTER_BUCKET_SECRET_KEY=REPLACE_WITH_SECRET
CHARACTER_BUCKET_PUBLIC_BASE_URL=https://REPLACE_ME
CHARACTER_BUCKET_SIGNED_URLS=1

# Expo notifications
EXPO_PUSH_ACCESS_TOKEN=REPLACE_WITH_EXPO_TOKEN
