{
  "name": "expo-runner-multiplayer-server",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node --import tsx src/index.ts",
    "start": "node --import tsx src/index.ts",
    "test": "node --import tsx --test src/tests/**/*.test.ts",
