{
  "name": "expo-runner-multiplayer-server",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "node --env-file-if-exists=.env --import tsx src/index.ts",
    "start": "node --env-file-if-exists=.env --import tsx src/index.ts",
    "test": "node --env-file-if-exists=.env --import tsx --test src/tests/**/*.test.ts",
    "typecheck": "tsc --noEmit --pretty false",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "scripts:jobs": "node --env-file-if-exists=.env --import tsx scripts/list-generation-jobs.ts",
    "scripts:smoke-generation": "node --import tsx scripts/smoke-test-generation.ts",
    "scripts:local-generation": "node --env-file-if-exists=.env --import tsx scripts/local-generation-with-wallet.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.888.0",
    "@aws-sdk/s3-request-presigner": "^3.888.0",
    "@google/genai": "^1.17.0",
    "@solana/wallet-standard-util": "^1.1.2",
    "@solana/web3.js": "^1.98.4",
    "cors": "^2.8.5",
    "drizzle-orm": "^0.43.1",
    "express": "^4.21.2",
    "jimp-compact": "^0.16.1",
    "pg": "^8.16.3",
    "pg-boss": "^10.3.3",
    "pngjs": "^7.0.0",
    "socket.io": "^4.8.1",
    "tweetnacl": "^1.0.3",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@types/express": "^5.0.3",
    "@types/pg": "^8.15.5",
    "drizzle-kit": "^0.31.4",
    "pg-mem": "^3.0.14",
    "tsx": "^4.20.3",
    "typescript": "^5.9.2"
  }
}
