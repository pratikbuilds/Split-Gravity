    "express": "^4.21.2",
    "pg": "^8.16.3",
    "pg-boss": "^10.3.3",
    "socket.io": "^4.8.1",
    "tweetnacl": "^1.0.3",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@types/express": "^5.0.3",
    "@types/pg": "^8.15.5",
    "drizzle-kit": "^0.31.4",
    "pg-mem": "^3.0.14",
