{
  "name": "my-expo-app",
  "version": "1.0.0",
  "scripts": {
    "android": "expo run:android",
    "ios": "expo run:ios",
    "dev": "expo start",
    "dev:server": "pnpm --dir server dev",
    "start": "expo start",
    "start:clear": "expo start --clear",
    "prebuild": "expo prebuild",
    "lint": "eslint \"**/*.{js,jsx,ts,tsx}\" && prettier -c \"**/*.{js,jsx,ts,tsx,json}\"",
    "test:deterministic": "pnpm --dir server test",
    "format": "eslint \"**/*.{js,jsx,ts,tsx}\" --fix && prettier \"**/*.{js,jsx,ts,tsx,json}\" --write",
    "web": "expo start --web",
    "audio:generate:sfx": "node scripts/generate-sfx.mjs",
    "audio:generate:sfx:force": "node scripts/generate-sfx.mjs --force"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@shopify/react-native-skia": "2.2.12",
    "@solana/web3.js": "^1.98.4",
    "@wallet-ui/react-native-web3js": "^4.0.1",
    "expo": "^54.0.0",
    "expo-av": "~16.0.8",
    "expo-constants": "^18.0.13",
    "expo-dev-client": "^6.0.20",
    "expo-file-system": "~19.0.17",
    "expo-image-picker": "~17.0.8",
    "expo-notifications": "~0.32.12",
    "expo-screen-orientation": "^9.0.8",
    "expo-status-bar": "~3.0.8",
    "nativewind": "latest",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-quick-crypto": "^1.0.16",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-worklets": "0.5.1",
    "socket.io-client": "^4.8.3"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "@types/react": "~19.1.10",
    "eslint": "^9.25.1",
    "eslint-config-expo": "~10.0.0",
    "eslint-config-prettier": "^10.1.2",
    "prettier": "^3.2.5",
    "prettier-plugin-tailwindcss": "^0.5.11",
    "tailwindcss": "^3.4.0",
    "typescript": "~5.9.2"
  },
  "main": "./index.js",
  "private": true
}
